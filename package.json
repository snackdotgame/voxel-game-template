{
  "name": "voxel-game-template",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/snackdotgame/voxel-game-template.git"
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev:client dev:server --parallel",
    "dev:client": "vite",
    "dev:server": "snack dev",
    "tc": "tsgo --project tsconfig.client.json --noEmit && tsgo --project tsconfig.server.json --noEmit",
    "typecheck": "tsgo --project tsconfig.client.json --noEmit && tsgo --project tsconfig.server.json --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "check": "oxfmt --check . && tsgo --project tsconfig.client.json --noEmit && tsgo --project tsconfig.server.json --noEmit && oxlint .",
    "build:client": "vite build",
    "build:server": "snack build",
    "build": "vite build && snack build",
    "deploy": "vite build && snack build && snack push",
    "publish": "vite build && snack build && node scripts/publish.mjs"
  },
  "dependencies": {
    "@types/three": "^0.184.1",
    "aabb-3d": "file:vendor/aabb-3d",
    "box-intersect": "file:vendor/box-intersect",
    "ent-comp": "^0.11.0",
    "events": "^3.3.0",
    "fast-voxel-raycast": "^0.1.1",
    "game-inputs": "^0.8.0",
    "gl-vec3": "^1.1.3",
    "micro-game-shell": "^0.9.0",
    "ndarray": "^1.0.19",
    "three": "^0.184.0",
    "voxel-aabb-sweep": "^0.5.0",
    "voxel-physics-engine": "file:vendor/voxel-physics-engine"
  },
  "devDependencies": {
    "@snack-game/cli": "^0.1.17",
    "@typescript/native-preview": "7.0.0-dev.20260513.1",
    "esbuild": "0.27.3",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "pngjs": "^7.0.0",
    "turbo": "2.7.2",
    "vite": "7.3.0"
  },
  "overrides": {
    "aabb-3d": "$aabb-3d"
  },
  "packageManager": "npm@11.12.1"
}
